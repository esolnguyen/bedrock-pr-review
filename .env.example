# Provider: "github_jira" or "azure_devops"
REVIEW_PROVIDER=github_jira

# AWS Credentials
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-v2:0

# --- GitHub + Jira provider ---
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO=owner/repo-name
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

JIRA_URL=https://your-domain.atlassian.net/
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your_jira_api_token_here

# --- Azure DevOps provider (via MCP proxy) ---
ADO_MCP_ENDPOINT=https://your-api-gw.execute-api.eu-central-1.amazonaws.com/prod/mcp
ADO_MCP_API_KEY=your_mcp_api_key_here
ADO_PROJECT=your-project-name
ADO_ORG=your-ado-org
ADO_PAT=your-personal-access-token
